digraph "adder1" {
label="adder1";
rankdir="LR";
remincross=true;
n2 [ shape=octagon, label="cout", color="black", fontcolor="black"];
n3 [ shape=octagon, label="s", color="black", fontcolor="black"];
n4 [ shape=octagon, label="cin", color="black", fontcolor="black"];
n5 [ shape=octagon, label="b", color="black", fontcolor="black"];
n6 [ shape=octagon, label="a", color="black", fontcolor="black"];
c10 [ shape=record, label="{{<p7> A|<p8> B}|$2\n$add|{<p9> Y}}",  ];
x0 [ shape=record, style=rounded, label="<s1> 8:8 - 0:0 |<s0> 7:0 - 7:0 ", colorscheme="dark28", color="8", fontcolor="8" ];
c10:p9:e -> x0:w [arrowhead=odiamond, arrowtail=odiamond, dir=both, colorscheme="dark28", color="5", fontcolor="5", style="setlinewidth(3)", label=""];
c11 [ shape=record, label="{{<p7> A|<p8> B}|$1\n$add|{<p9> Y}}",  ];
c11:p9:e -> c10:p7:w [colorscheme="dark28", color="1", fontcolor="1", style="setlinewidth(3)", label=""];
x0:s1:e -> n2:w [colorscheme="dark28", color="1", fontcolor="1", label=""];
x0:s0:e -> n3:w [colorscheme="dark28", color="3", fontcolor="3", style="setlinewidth(3)", label=""];
n4:e -> c10:p8:w [colorscheme="dark28", color="4", fontcolor="4", label=""];
n5:e -> c11:p8:w [colorscheme="dark28", color="4", fontcolor="4", style="setlinewidth(3)", label=""];
n6:e -> c11:p7:w [colorscheme="dark28", color="3", fontcolor="3", style="setlinewidth(3)", label=""];
}
