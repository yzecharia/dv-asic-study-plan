{
  "version": "2.0.0",
  "tasks": [

    {
      "label": "🔍 LINT (xvlog only — syntax check, no elaboration)",
      "type": "shell",
      "command": "${workspaceFolder}/xflow.sh",
      "args": ["lint", "${file}"],
      "group": "build",
      "presentation": { "clear": true, "reveal": "always", "group": "xsim" },
      "problemMatcher": {
        "owner": "xvlog",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+\\[\\w+ \\d+-\\d+\\]\\s+(.*?)\\s+\\[(.+?):(\\d+)\\]",
          "message": 1,
          "file": 2,
          "line": 3
        }
      }
    },

    {
      "label": "🔬 CHECK (syntax + elaboration, no simulation)",
      "type": "shell",
      "command": "${workspaceFolder}/xflow.sh",
      "args": ["check", "${file}"],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "clear": true, "reveal": "always", "group": "xsim" },
      "problemMatcher": {
        "owner": "xvlog",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+\\[\\w+ \\d+-\\d+\\]\\s+(.*?)\\s+\\[(.+?):(\\d+)\\]",
          "message": 1,
          "file": 2,
          "line": 3
        }
      }
    },

    {
      "label": "🔧 SCHEMATIC (yosys + slang gate-level schematic)",
      "type": "shell",
      "command": "${workspaceFolder}/run_yosys_slang.sh",
      "args": ["${file}"],
      "group": "build",
      "presentation": { "clear": true, "reveal": "always", "group": "yosys" }
    },

    {
      "label": "🌊 SIM (one-shot: compile + run, cleans up after)",
      "type": "shell",
      "command": "UVM_TESTNAME=${input:uvmTestName} SV_SEED=${input:svSeed} UVM_VERBOSITY=${input:uvmVerbosity} ${workspaceFolder}/xflow.sh sim ${file}",
      "group": "build",
      "presentation": { "clear": true, "reveal": "always", "group": "xsim" },
      "problemMatcher": {
        "owner": "xsim",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+\\[\\w+ \\d+-\\d+\\]\\s+(.*?)\\s+\\[(.+?):(\\d+)\\]",
          "message": 1,
          "file": 2,
          "line": 3
        }
      }
    },

    {
      "label": "🔨 COMPILE (build snapshot, keep for reuse)",
      "type": "shell",
      "command": "${workspaceFolder}/xflow.sh",
      "args": ["compile", "${file}"],
      "group": "build",
      "presentation": { "clear": true, "reveal": "always", "group": "xsim" },
      "problemMatcher": {
        "owner": "xsim",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+\\[\\w+ \\d+-\\d+\\]\\s+(.*?)\\s+\\[(.+?):(\\d+)\\]",
          "message": 1,
          "file": 2,
          "line": 3
        }
      }
    },

    {
      "label": "▶️  RUN (test against existing snapshot)",
      "type": "shell",
      "command": "UVM_VERBOSITY=${input:uvmVerbosity} SV_SEED=${input:svSeed} ${workspaceFolder}/xflow.sh run ${input:uvmTestName} ${fileDirname}",
      "group": "build",
      "presentation": { "clear": true, "reveal": "always", "group": "xsim" },
      "problemMatcher": {
        "owner": "xsim",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+\\[\\w+ \\d+-\\d+\\]\\s+(.*?)\\s+\\[(.+?):(\\d+)\\]",
          "message": 1,
          "file": 2,
          "line": 3
        }
      }
    },

    {
      "label": "🧹 CLEAN (wipe xsim build artefacts)",
      "type": "shell",
      "command": "${workspaceFolder}/run_xsim_clean.sh",
      "args": ["${fileDirname}"],
      "group": "build",
      "presentation": { "clear": true, "reveal": "always", "group": "xsim" }
    },

    {
      "label": "♻️  REBUILD (clean + compile + run — fresh snapshot)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "🧹 CLEAN (wipe xsim build artefacts)",
        "🔨 COMPILE (build snapshot, keep for reuse)",
        "▶️  RUN (test against existing snapshot)"
      ],
      "group": "build",
      "presentation": { "clear": false, "reveal": "always", "group": "xsim" },
      "problemMatcher": []
    },

    {
      "label": "📈 BADGES (update progress shields)",
      "type": "shell",
      "command": "python3",
      "args": ["${workspaceFolder}/tools/update_progress_badges.py"],
      "group": "build",
      "presentation": { "clear": true, "reveal": "always" }
    }

  ],
  "inputs": [
    {
      "id": "uvmTestName",
      "type": "promptString",
      "description": "UVM test name (e.g. random_test). Empty for non-UVM TBs.",
      "default": ""
    },
    {
      "id": "svSeed",
      "type": "promptString",
      "description": "SV random seed (empty = default)",
      "default": ""
    },
    {
      "id": "uvmVerbosity",
      "type": "pickString",
      "description": "UVM verbosity (empty = default UVM_MEDIUM)",
      "options": ["", "UVM_NONE", "UVM_LOW", "UVM_MEDIUM", "UVM_HIGH", "UVM_FULL", "UVM_DEBUG"],
      "default": ""
    }
  ]
}
