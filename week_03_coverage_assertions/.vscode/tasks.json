{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "0a. Check Syntax (RTL Only)",
      "type": "shell",
      "command": "iverilog -g2012 -t null $(find homework -name '*.sv' -not -name '*_tb.sv')",
      "group": "build",
      "presentation": { "clear": true, "reveal": "silent" },
      "problemMatcher": {
        "owner": "verilog",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^([^:]+):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    },
    {
      "label": "0b. Check Syntax (RTL + TB)",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; iverilog -g2012 -t null $(find homework -name '*.sv' -not -name '*_tb.sv') tb/${MOD}_tb.sv",
      "group": "build",
      "presentation": { "clear": true, "reveal": "silent" },
      "problemMatcher": {
        "owner": "verilog",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^([^:]+):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    },
    {
      "label": "1. Compile for Simulation (Icarus)",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; mkdir -p build waves && iverilog -g2012 -o build/${MOD}.out $(find homework -name '*.sv' -not -name '*_tb.sv') tb/${MOD}_tb.sv",
      "group": "build",
      "presentation": { "clear": true, "group": "sim" },
      "problemMatcher": {
        "owner": "verilog",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^([^:]+):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    },
    {
      "label": "2. Run simulation",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; vvp build/${MOD}.out",
      "dependsOn": "1. Compile for Simulation (Icarus)",
      "presentation": { "clear": false, "group": "sim" }
    },
    {
      "label": "3. Open waveform (Surfer)",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; code -r waves/${MOD}.vcd",
      "dependsOn": "2. Run simulation",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "4. Generate JSON (Yosys)",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; mkdir -p build .yosys_tmp && for f in $(find homework -name '*.sv' -not -name '*_tb.sv'); do sed '/^[[:space:]]*timeunit/d;/^[[:space:]]*timeprecision/d' \"$f\" > \".yosys_tmp/$(basename $f)\"; done && yosys -p \"read_verilog -sv .yosys_tmp/*.sv; prep -top ${MOD}; write_json build/${MOD}.json\" && rm -rf .yosys_tmp",
      "dependsOn": "0a. Check Syntax (RTL Only)",
      "presentation": { "clear": true, "group": "rtl" },
      "problemMatcher": {
        "owner": "yosys",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+(.*\\.sv):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    },
    {
      "label": "5. Generate SVG (netlistsvg)",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; mkdir -p schematics && netlistsvg build/${MOD}.json -o ${fileDirname}/${MOD}.svg",
      "dependsOn": "4. Generate JSON (Yosys)",
      "presentation": { "group": "rtl" }
    },
    {
      "label": "6. Fix SVG Background",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; sed -i '' 's/<svg /<svg style=\"background:white\" /' ${fileDirname}/${MOD}.svg",
      "dependsOn": "5. Generate SVG (netlistsvg)",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "7. Open RTL schematic",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; open ${fileDirname}/${MOD}.svg",
      "dependsOn": "6. Fix SVG Background",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "🌊 FLOW: SIM ONLY (Simulation + Waves)",
      "dependsOn": [
        "3. Open waveform (Surfer)"
      ],
      "group": "build"
    },
    {
      "label": "🛠️ FLOW: RTL ONLY (Syntax + Schematics)",
      "dependsOn": [
        "7. Open RTL schematic"
      ],
      "group": "build"
    },
    {
      "label": "🚀 FLOW: FULL (Sim + Schematics)",
      "dependsOn": [
        "3. Open waveform (Surfer)",
        "7. Open RTL schematic"
      ],
      "group": "build"
    },
    {
      "label": "T1. Compile TB Only (no RTL)",
      "type": "shell",
      "command": "mkdir -p build waves && iverilog -g2012 -o build/${fileBasenameNoExtension}.out ${file}",
      "group": "build",
      "presentation": { "clear": true, "group": "tb" },
      "problemMatcher": {
        "owner": "verilog",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^([^:]+):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    },
    {
      "label": "T2. Run TB Only",
      "type": "shell",
      "command": "vvp build/${fileBasenameNoExtension}.out",
      "dependsOn": "T1. Compile TB Only (no RTL)",
      "presentation": { "clear": false, "group": "tb" }
    },
    {
      "label": "T3. Open TB waveform",
      "type": "shell",
      "command": "code -r waves/${fileBasenameNoExtension}.vcd",
      "dependsOn": "T2. Run TB Only",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "📝 FLOW: TB ONLY (Standalone testbench)",
      "dependsOn": [
        "T2. Run TB Only"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "📝+🌊 FLOW: TB + Waves (Standalone TB with waveform)",
      "dependsOn": [
        "T3. Open TB waveform"
      ],
      "group": "build"
    },
    {
      "label": "X1. xsim: Compile + Run TB Only",
      "type": "shell",
      "command": "SV_SEED=${input:svSeed} ${workspaceFolder}/../run_xsim_auto.sh ${file}",
      "group": "build",
      "presentation": { "clear": true, "group": "xsim" },
      "problemMatcher": {
        "owner": "xsim",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+\\[\\w+ \\d+-\\d+\\]\\s+(.*?)\\s+\\[(.+?):(\\d+)\\]",
          "message": 1,
          "file": 2,
          "line": 3
        }
      }
    },
    {
      "label": "X2. xsim: Compile + Run RTL + TB",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; SV_SEED=${input:svSeed} ${workspaceFolder}/../run_xsim.sh -top ${MOD}_tb rtl/${MOD}.sv tb/${MOD}_tb.sv",
      "group": "build",
      "presentation": { "clear": true, "group": "xsim" },
      "problemMatcher": {
        "owner": "xsim",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+\\[\\w+ \\d+-\\d+\\]\\s+(.*?)\\s+\\[(.+?):(\\d+)\\]",
          "message": 1,
          "file": 2,
          "line": 3
        }
      }
    },
    {
      "label": "🔬 FLOW: XSIM TB (Full SV — standalone TB via Vivado)",
      "dependsOn": [
        "X1. xsim: Compile + Run TB Only"
      ],
      "group": "build"
    },
    {
      "label": "🔬 FLOW: XSIM RTL+TB (Full SV — RTL + TB via Vivado)",
      "dependsOn": [
        "X2. xsim: Compile + Run RTL + TB"
      ],
      "group": "build"
    },
    {
      "label": "X3. xsim: Compile RTL Only",
      "type": "shell",
      "command": "${workspaceFolder}/../run_xsim.sh ${file}",
      "group": "build",
      "presentation": { "clear": true, "group": "xsim" },
      "problemMatcher": {
        "owner": "xsim",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+\\[\\w+ \\d+-\\d+\\]\\s+(.*?)\\s+\\[(.+?):(\\d+)\\]",
          "message": 1,
          "file": 2,
          "line": 3
        }
      }
    },
    {
      "label": "🔬 FLOW: XSIM RTL (Compile + Elaborate RTL via Vivado)",
      "dependsOn": [
        "X3. xsim: Compile RTL Only"
      ],
      "group": "build"
    },
    {
      "label": "Y1. Yosys: Synthesize + Optimize (FSM)",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; mkdir -p build .yosys_tmp && for f in $(find homework -name '*.sv' -not -name '*_tb.sv'); do sed '/^[[:space:]]*timeunit/d;/^[[:space:]]*timeprecision/d' \"$f\" > \".yosys_tmp/$(basename $f)\"; done && yosys -p \"read_verilog -sv .yosys_tmp/*.sv; hierarchy -top ${MOD}; proc; opt; fsm_detect; fsm_extract; fsm_opt; fsm_recode -encoding ${input:fsmEncoding}; opt; clean; stat; write_json build/${MOD}_opt.json\" && rm -rf .yosys_tmp",
      "group": "build",
      "presentation": { "clear": true, "group": "synth" },
      "problemMatcher": {
        "owner": "yosys",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ERROR:\\s+(.*\\.sv):(\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    },
    {
      "label": "Y2. Generate Optimized SVG",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; mkdir -p schematics && netlistsvg build/${MOD}_opt.json -o ${fileDirname}/${MOD}_opt.svg && sed -i '' 's/<svg /<svg style=\"background:white\" /' ${fileDirname}/${MOD}_opt.svg",
      "dependsOn": "Y1. Yosys: Synthesize + Optimize (FSM)",
      "presentation": { "group": "synth" }
    },
    {
      "label": "Y3. Open Optimized Schematic",
      "type": "shell",
      "command": "MOD=\"${fileBasenameNoExtension}\"; MOD=\"${MOD%_tb}\"; open ${fileDirname}/${MOD}_opt.svg",
      "dependsOn": "Y2. Generate Optimized SVG",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "⚡ FLOW: SYNTH (Yosys Optimize + Schematic)",
      "dependsOn": [
        "Y3. Open Optimized Schematic"
      ],
      "group": "build"
    }
  ],
  "inputs": [
    {
      "id": "svSeed",
      "type": "promptString",
      "description": "SV random seed (leave empty for default)",
      "default": ""
    },
    {
      "id": "fsmEncoding",
      "type": "pickString",
      "description": "FSM state encoding",
      "options": ["auto", "one-hot", "binary", "none"],
      "default": "auto"
    }
  ]
}
